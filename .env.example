EB_APPLICATION_ID=
# Local dev:        ./keys/private.pem
# Docker container: /app/keys/private.pem  (volume-mounted, read-only)
EB_PRIVATE_KEY_PATH=./keys/private.pem
# Or, instead of a path, paste the PEM directly (use \n for newlines):
# EB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Passphrase used to derive the AES-256-GCM key that encrypts stored
# provider credentials (e.g. Avanza session cookies). Treat like a
# database master password: rotate = all stored credentials become
# unreadable. Generate with:  openssl rand -hex 32
BANKING_SECRET=
